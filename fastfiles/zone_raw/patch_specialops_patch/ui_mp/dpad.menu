        {
            rect                        -72 -100.6667 28 28 10 10
            decoration                  
            visible                     when( actionslotusable( 4 ) );
            textalign                   10
            textscale                   0.25
            textstyle                   6
            textfont                    6
            forecolor                   1 1 1 1
            exp text                    "^7" + keybinding( "+actionslot 4" );
            exp rect y                  ( -100 ) - 32 * actionslotusable( 2 );
