            textfont                    6
            forecolor                   1 1 1 1
            exp text                    "^7" + keybinding( "+actionslot 3" );
            exp rect y                  ( -100 ) - 32 * ( actionslotusable( 2 ) + actionslotusable( 4 ) );
        }

