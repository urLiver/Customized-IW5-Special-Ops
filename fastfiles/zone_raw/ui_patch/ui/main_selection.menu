                open offensive_warning;
            }

            setLocalVarString ui_so_time_text (select((gettimeplayed("so", "days") > 0), gettimeplayed("so", "dhms"), gettimeplayed("so", "hms")));
            setLocalVarString ui_so_comp_text (select((int((min(1, int(int(getprofiledata("percentCompleteSO")) % 100) / int(tablelookup("sp/rankTable.csv", 0, "maxrank", 1))) * 100 * 10) % 10) == 0), (locstring("@MENU_SP_STAT_NUM_PERCENT_COMPLETE", int(min(1, int(int(getprofiledata("percentCompleteSO")) % 100) / int(tablelookup("sp/rankTable.csv", 0, "maxrank", 1))) * 100))), (locstring("@MENU_SP_STAT_NUM_DOT_PERCENT_COMPLETE", int(min(1, int(int(getprofiledata("percentCompleteSO")) % 100) / int(tablelookup("sp/rankTable.csv", 0, "maxrank", 1))) * 100), int((min(1, int(int(getprofiledata("percentCompleteSO")) % 100) / int(tablelookup("sp/rankTable.csv", 0, "maxrank", 1))) * 100 * 10) % 10)))));
            setLocalVarString ui_sp_time_text (select((gettimeplayed("sp", "days") > 0), gettimeplayed("sp", "dhms"), gettimeplayed("sp", "hms")));
            setLocalVarString ui_sp_comp_text (select((int(((getprofiledata("percentCompleteSP") / 100) * 10) % 10) == 0), (locstring("@MENU_SP_STAT_NUM_PERCENT_COMPLETE", int((getprofiledata("percentCompleteSP") / 100)))), (locstring("@MENU_SP_STAT_NUM_DOT_PERCENT_COMPLETE", int((getprofiledata("percentCompleteSP") / 100)), int(((getprofiledata("percentCompleteSP") / 100) * 10) % 10)))));
           
            savegamesetlocalbool ui_save_available;

