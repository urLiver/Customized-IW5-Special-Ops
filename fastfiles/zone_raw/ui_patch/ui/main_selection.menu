#include "ui/utils/animations.inc"
#include "ui/utils/game_defaults.inc"

#define Button_MainMenu( x_, y_, w_, h_, text_, anim_name_, function_ ) \
    itemDef \
    { \
        rect                        ( x_ ) ( y_ ) ( w_ ) ( h_ ) 4 4 \
        style                       1 \
        type                        1 \
        visible                     1 \
        Animation_Focus( anim_name_ ); \
        action \
        { \
            function_; \
            play mouse_click; \
        } \
    } \
    itemDef \
    { \
        rect                        ( x_ ) ( y_ ) ( w_ ) ( h_ ) 4 4 \
        style                       1 \
        decoration                    \
        visible                     1 \
        textalign                   ALIGN_MIDDLE_CENTER \
        textscale                   0.275 \
        textfont                    FONT_NORMAL \
        text                        ( text_ ) \
        forecolor                   1 1 1 1 \
        exp forecolor r             ( 1 - Animation_Get( anim_name_, 250 ) * 0.75 ) \   
        exp forecolor b             ( 1 - Animation_Get( anim_name_, 250 ) * 0.75 ) \
    } \
    itemDef \
    { \
        rect                        0 0 0 1 4 4 \
        style                       1 \
        decoration                    \
        visible                     1 \
        backcolor                   0.25 1 0.25 1 \
        background                  "white" \
        exp rect w                  ( getTextWidth( locstring( text_ ), FONT_NORMAL, 0.275 ) *  Animation_Get( anim_name_, 250 ) ) \
        exp rect x                  ( x_ + w_ / 2 - ( getTextWidth( locstring( text_ ), FONT_NORMAL, 0.275 ) *  Animation_Get( anim_name_, 250 ) ) / 2 ) \
        exp rect y                  ( y_ + h_ / 2 + getTextHeight( FONT_NORMAL, 0.275 ) / 2 ) \
    }

#define Button_MainMenuLocked( x_, y_, w_, h_, text_, anim_name_, function_, locked_ ) \
    itemDef \
    { \
        rect                        ( x_ ) ( y_ ) ( w_ ) ( h_ ) 4 4 \
        style                       1 \
        type                        1 \
        visible                     1 \
        Animation_Focus( anim_name_ ); \
        exp disabled                ( ! locked_ ) \
        action \
        { \
            function_; \
            play mouse_click; \
        } \
    } \
    itemDef \
    { \
        rect                        ( x_ ) ( y_ ) ( w_ ) ( h_ ) 4 4 \
        style                       1 \
        decoration                    \
        visible                     1 \
        textalign                   ALIGN_MIDDLE_CENTER \
        textscale                   0.275 \
        textfont                    FONT_NORMAL \
        text                        ( text_ ) \
        forecolor                   1 1 1 1 \
        exp forecolor r             ( select( locked_, 1 - Animation_Get( anim_name_, 250 ) * 0.75, 0.25 ) ) \   
        exp forecolor g             ( select( locked_, 1, 0.25 ) ) \
        exp forecolor b             ( select( locked_, 1 - Animation_Get( anim_name_, 250 ) * 0.75, 0.25 ) ) \
    } \
    itemDef \
    { \
        rect                        0 0 0 1 4 4 \
        style                       1 \
        decoration                    \
        visible                     1 \
        backcolor                   0.25 1 0.25 1 \
        background                  "white" \
        exp rect w                  ( getTextWidth( locstring( text_ ), FONT_NORMAL, 0.275 ) *  Animation_Get( anim_name_, 250 ) ) \
        exp rect x                  ( x_ + w_ / 2 - ( getTextWidth( locstring( text_ ), FONT_NORMAL, 0.275 ) *  Animation_Get( anim_name_, 250 ) ) / 2 ) \
        exp rect y                  ( y_ + h_ / 2 + getTextHeight( FONT_NORMAL, 0.275 ) / 2 ) \
    }

#define Spacer_Simple( x_, y_, w_, h_, color_ ) \
    itemDef \
    { \
        rect                        ( x_ ) ( y_ ) ( w_ ) ( h_ ) 4 4 \
        style                       1 \
        decoration                    \
        visible                     1 \
        backcolor                   color_ \
        background                  "white" \
    }

#define Lables_ExpNormal( x_, y_, w_, h_, text_, font_size_, alignment_ ) \
    itemDef \
    { \
        rect                        ( x_ ) ( y_ ) ( w_ ) ( h_ ) 4 4 \
        style                       1 \
        decoration                    \
        visible                     1 \
        forecolor                   1 1 1 1 \
        textalign                   alignment_ \
        textscale                   font_size_ \
        textfont                    FONT_NORMAL \
        exp text                    ( text_ ) \
    }

#define Lables_Bold( x_, y_, w_, h_, text_, font_size_, alignment_ ) \
    itemDef \
    { \
        rect                        ( x_ ) ( y_ ) ( w_ ) ( h_ ) 4 4 \
        style                       1 \
        decoration                    \
        visible                     1 \
        forecolor                   1 1 1 1 \
        textalign                   alignment_ \
        textscale                   font_size_ \
        textfont                    FONT_BOLD \
        text                        ( text_ ) \
    }

