            exp material                "missions_color";
            exp forecolor a             ( Animation_Get( "button_2", 125 ) );
        }

        itemDef
        {
            rect                        0 200 460 88 2 2
            style                       3
            decoration                  
            visible                     1
            exp material                "chaos_desat";
        }

        itemDef
        {
            rect                        0 200 460 88 2 2
            style                       3
            decoration                  
            visible                     1
            exp material                "chaos_color";
            exp forecolor a             ( Animation_Get( "button_3", 125 ) );
        }

        itemDef
        {
            rect                        0 112 460 12 2 2
            style                       3
            decoration                  
            visible                     1
            exp material                "navbar_selection_bar_shadow";
        }

        itemDef
        {
            rect                        0 200 460 12 2 2
            style                       3
            decoration                  
            visible                     1
            exp material                "navbar_selection_bar_shadow";
        }

        itemDef
        {
            rect                        0 288 460 12 2 2
            style                       3
            decoration                  
            visible                     1
            exp material                "navbar_selection_bar_shadow";
        }

        itemDef
        {
            rect                        8 82.667 444 20 2 2
            style                       1
            decoration                  
            autowrapped                 
            visible                     1
            textalign                   4
            textscale                   0.4375
            textstyle                   8
            textfont                    9
            exp text                    "@MENU_SP_SURVIVAL_MODE_CAPS";
            exp forecolor r             ( Animation_Get( "button_1", 125 ) * 0.5 + 0.5 );
            exp forecolor g             ( Animation_Get( "button_1", 125 ) * 0.5 + 0.5 );
            exp forecolor b             ( Animation_Get( "button_1", 125 ) * 0.5 + 0.5 );
        }

        itemDef
        {
            rect                        8 172.667 444 20 2 2
            style                       1
            decoration                  
            autowrapped                 
            visible                     1
            textalign                   4
            textscale                   0.4375
            textstyle                   8
            textfont                    9
            exp text                    "@MENU_SP_MISSION_MODE_CAPS";
            exp forecolor r             ( Animation_Get( "button_2", 125 ) * 0.5 + 0.5 );
            exp forecolor g             ( Animation_Get( "button_2", 125 ) * 0.5 + 0.5 );
            exp forecolor b             ( Animation_Get( "button_2", 125 ) * 0.5 + 0.5 );
